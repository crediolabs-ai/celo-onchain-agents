# Network — Celo mainnet. V2 Etherscan unified endpoint — `chainid` query
# param picks the network (Celo mainnet = 42220, Celo Sepolia = 11142220).
# Note: Alfajores (chainid 44787) is NOT supported by V2, so the deprecated
# V1 Celoscan endpoint is the only remaining option for Alfajores — but V1
# is being shut down. Recommend mainnet or Sepolia.
NETWORK=mainnet
CELO_RPC_URL=https://forno.celo.org
CELOSCAN_API_URL=https://api.etherscan.io/v2/api
CELOSCAN_API_KEY=

# Price data
# DefiLlama is fully public — no API key needed.

# LLM (Tuan's domain)
# Anthropic model alias for both query interface + tx-classifier LLM fallback.
# Default: claude-sonnet-4-6.
AGENT_LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Agent EOA (generated via scripts/generate-wallet.ts)
AGENT_WALLET_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=0xb302195497B820DCE5852FCB618408549fb62e96

# Behavior
LOG_LEVEL=info
CACHE_DIR=./.cache
