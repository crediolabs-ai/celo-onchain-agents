# Celo RPC — public mainnet node (no API key required)
CELO_RPC_URL=https://forno.celo.org

# Celoscan V2 API (Etherscan-compatible unified endpoint)
# chainid=42220 for Celo mainnet
CELOSCAN_API_URL=https://api.etherscan.io/v2/api
CELOSCAN_API_KEY=

# CoinGecko (free tier works; set key for higher rate limits)
COINGECKO_API_KEY=

# alfajores | mainnet
NETWORK=mainnet

# debug | info | warn | error
LOG_LEVEL=info
