{
  "name": "celo-onchain-agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent 06 — L3 Onchain Tax & Portfolio Agent for Celo. Celo Onchain Agents Hackathon 2026.",
  "engines": {
    "node": ">=20.18"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "demo": "tsx src/cli/demo.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "wallet:generate": "tsx scripts/generate-wallet.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "p-limit": "^6.2.0",
    "viem": "^2.52.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
